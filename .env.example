# Copy to .env.local and fill in from your Supabase project (Settings → API Keys).
# Use the PUBLISHABLE key (sb_publishable_...). It is public-safe (protected by
# read-only RLS). NEVER put the secret key (sb_secret_...) here or in the repo.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx

# If these are unset, the app runs on bundled demo content (src/data/fallbackContent.ts).
