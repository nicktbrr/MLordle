# Copy to .env.local and fill in from your Supabase project (Settings → API).
# The anon key is public-safe (protected by read-only RLS). NEVER put the
# service_role key here or anywhere in the client / repo.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# If these are unset, the app runs on bundled demo content (src/data/fallbackContent.ts).
